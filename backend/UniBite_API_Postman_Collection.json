							"mode": "raw",
							"raw": "{\n    \"name\": \"Delivery Rider\",\n    \"email\": \"rider@unibite.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"phone\": \"+1234567892\",\n    \"role\": \"rider\"\n}"
